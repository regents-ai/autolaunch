<!DOCTYPE html>
<html lang="en" data-brand="autolaunch" data-theme="light">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="autolaunch.sh" suffix=" | Regent CCA">
      {assigns[:page_title]}
    </.live_title>
    <link rel="icon" type="image/png" sizes="32x32" href={~p"/favicon.png"} />
    <link rel="apple-touch-icon" sizes="180x180" href={~p"/apple-touch-icon.png"} />
    <link phx-track-static rel="stylesheet" href={~p"/assets/css/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/js/app.js"}></script>
    <script>
      (() => {
        const themeKey = "autolaunch:theme";
        const applyTheme = (theme) => {
          document.documentElement.setAttribute("data-brand", "autolaunch");
          document.documentElement.setAttribute("data-theme", theme);
          localStorage.setItem(themeKey, theme);
        };
        applyTheme(localStorage.getItem(themeKey) || "light");
        window.addEventListener("autolaunch:set-theme", (event) => {
          applyTheme(event.detail?.theme || "light");
        });
      })();
    </script>
  </head>
  <body class="al-shell-body">
    <Layouts.app_shell
      current_human={assigns[:current_human]}
      active_view={assigns[:active_view]}
      page_title={assigns[:page_title]}
      wallet_switch={assigns[:wallet_switch]}
    >
      {@inner_content}
    </Layouts.app_shell>
  </body>
</html>
