# Base launch rehearsal and production inputs.
# Keep real values in a local env file and use an encrypted Foundry keystore.

# Broadcast identity
AUTOLAUNCH_DEPLOY_ACCOUNT=
AUTOLAUNCH_DEPLOY_SENDER=

# Common owner / safe values
STRATEGY_OPERATOR=
REGENT_MULTISIG_ADDRESS=
AUTOLAUNCH_AGENT_ID=84532:42
AUTOLAUNCH_TOKEN_NAME=Regent Agent Token
AUTOLAUNCH_TOKEN_SYMBOL=RAGENT
AUTOLAUNCH_SUBJECT_LABEL=Regent Agent Token
AUTOLAUNCH_TOTAL_SUPPLY=100000000000000000000000000000
AUTOLAUNCH_TOKEN_METADATA_DESCRIPTION=
AUTOLAUNCH_TOKEN_METADATA_WEBSITE=
AUTOLAUNCH_TOKEN_METADATA_IMAGE=

# Shared Regent Autolaunch infra deployment
# forge script scripts/DeployAutolaunchInfra.s.sol:DeployAutolaunchInfraScript --sig "deployFromEnv()"
AUTOLAUNCH_INFRA_OWNER=
BASE_REGENT_TOKEN_ADDRESS=0x6f89bcA4eA5931EdFCB09786267b251DeE752b07
BASE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913
AUTOLAUNCH_REVENUE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7c32d4f71b54bda02913

# Addresses returned by DeployAutolaunchInfra.s.sol
AUTOLAUNCH_REVENUE_SHARE_FACTORY_ADDRESS=
AUTOLAUNCH_REVENUE_INGRESS_FACTORY_ADDRESS=
SUBJECT_REGISTRY_ADDRESS=
AUTOLAUNCH_LBP_STRATEGY_FACTORY_ADDRESS=

# UERC20 factory deployment
# forge script scripts/DeployUERC20Factory.s.sol:DeployUERC20FactoryScript --rpc-url "$AUTOLAUNCH_RPC_URL" --account "$AUTOLAUNCH_DEPLOY_ACCOUNT" --sender "$AUTOLAUNCH_DEPLOY_SENDER" --broadcast
# Set this from UERC20_FACTORY_RESULT_JSON.factoryAddress.
AUTOLAUNCH_TOKEN_FACTORY_ADDRESS=

# Launch deployment inputs
# forge script scripts/ExampleCCADeploymentScript.s.sol:ExampleCCADeploymentScript --rpc-url "$AUTOLAUNCH_RPC_URL" --account "$AUTOLAUNCH_DEPLOY_ACCOUNT" --sender "$AUTOLAUNCH_DEPLOY_SENDER"
AUTOLAUNCH_RPC_URL=
BASE_MAINNET_RPC_URL=
BASE_SEPOLIA_RPC_URL=
AUTOLAUNCH_CCA_FACTORY_ADDRESS=0xCCccCcCAE7503Cac057829BF2811De42E16e0bD5
AUTOLAUNCH_UNISWAP_V4_POOL_MANAGER=
AUTOLAUNCH_UNISWAP_V4_POSITION_MANAGER=
AUTOLAUNCH_FACTORY_OWNER_ADDRESS=
AUTOLAUNCH_AGENT_SAFE_ADDRESS=
# Optional launch identity link.
AUTOLAUNCH_IDENTITY_REGISTRY_ADDRESS=
AUTOLAUNCH_AUCTION_QUOTE_TOKEN_ADDRESS=0x6f89bcA4eA5931EdFCB09786267b251DeE752b07
AUTOLAUNCH_REVENUE_USDC_ADDRESS=0x833589fCD6eDb6E08f4c7c32d4f71b54bda02913
OFFICIAL_POOL_FEE=0
OFFICIAL_POOL_TICK_SPACING=60
AUCTION_DURATION_BLOCKS=86400
CCA_START_BLOCK_OFFSET=300
CCA_TICK_SPACING_Q96=
CCA_FLOOR_PRICE_Q96=
CCA_REQUIRED_CURRENCY_RAISED=
CCA_CLAIM_BLOCK_OFFSET=64
LBP_MIGRATION_BLOCK_OFFSET=128
LBP_SWEEP_BLOCK_OFFSET=256
CCA_VALIDATION_HOOK=

# Separate Base-mainnet REGENT staking rail
# forge script scripts/DeployRegentRevenueStaking.s.sol:DeployRegentRevenueStakingScript --sig "deployFromEnv()"
BASE_REGENT_TOKEN_ADDRESS=
REGENT_REVENUE_STAKING_ADDRESS=
