# Ethereum RPC endpoints
ETH_SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
ETH_MAINNET_RPC_URL=https://ethereum-rpc.publicnode.com

# Deployment private key used by forge script --private-key
# Keep this in a private `.env`, never commit secrets.
CCA_DEPLOYER_PRIVATE_KEY=

# Common owner / safe values
DEPLOYER=
AUTOLAUNCH_RECOVERY_SAFE_ADDRESS=
AUTOLAUNCH_AUCTION_PROCEEDS_RECIPIENT=
AUTOLAUNCH_ETHEREUM_REVENUE_TREASURY=
AUTOLAUNCH_EMISSION_RECIPIENT=
REGENT_MULTISIG_ADDRESS=
AUTOLAUNCH_AGENT_ID=1:42
AGENT_NAME=Regent Agent Token
AGENT_SYMBOL=RAGENT
AUTOLAUNCH_SUBJECT_LABEL=Regent Agent Token
TOTAL_SUPPLY=100000000000000000000000000000

# Shared Autolaunch infra deployment
# forge script scripts/DeployAutolaunchInfra.s.sol:DeployAutolaunchInfraScript --sig "deployFromEnv()"
AUTOLAUNCH_INFRA_OWNER=

# Addresses returned by DeployAutolaunchInfra.s.sol
REVENUE_SHARE_FACTORY_ADDRESS=
REVENUE_INGRESS_FACTORY_ADDRESS=
REVENUE_INGRESS_ROUTER_ADDRESS=
SUBJECT_REGISTRY_ADDRESS=

# Launch deployment inputs
# forge script scripts/ExampleCCADeploymentScript.s.sol:ExampleCCADeploymentScript --sig "deployFromEnv()"
UNISWAP_V4_POOL_MANAGER=
FACTORY_ADDRESS=0xCCccCcCAE7503Cac057829BF2811De42E16e0bD5
AUTOLAUNCH_IDENTITY_REGISTRY_ADDRESS=
ETHEREUM_USDC_ADDRESS=
MAINNET_REGENT_EMISSIONS_CONTROLLER_ADDRESS=
OFFICIAL_POOL_FEE=0
OFFICIAL_POOL_TICK_SPACING=60
AUCTION_DURATION_BLOCKS=21600
CCA_STEP_MPS=100000
CCA_STEP_BLOCK_DELTA=216
CCA_TICK_SPACING_Q96=
CCA_FLOOR_PRICE_Q96=
CCA_REQUIRED_CURRENCY_RAISED=
CCA_CLAIM_BLOCK_OFFSET=0
PROTOCOL_SKIM_BPS=100
CCA_VALIDATION_HOOK=

# Mainnet REGENT emissions controller deployment
# forge script scripts/DeployMainnetRegentEmissionsController.s.sol:DeployMainnetRegentEmissionsControllerScript --sig "deployFromEnv()"
REGENT_TOKEN_ADDRESS=
ETH_MAINNET_USDC_ADDRESS=
REGENT_USDC_TREASURY=
REGENT_EMISSIONS_OWNER=
REVENUE_EPOCH_GENESIS_TS=1700000000
REVENUE_EPOCH_LENGTH=259200
REGENT_EMISSIONS_CHAIN_ID=1

# Optional / legacy rails kept in source
# forge script scripts/DeployRegentEmissionsDistributor.s.sol:DeployRegentEmissionsDistributorScript --sig "deployFromEnv()"
REGENT_EMISSIONS_DISTRIBUTOR_ADDRESS=
